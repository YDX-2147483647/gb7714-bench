# Collect the versions of LaTeX processors from logs generated by previous runs.
def main []: nothing -> string {
    cd ($env.CURRENT_FILE | path dirname | path dirname)
    cd processors/

    ['gbt7714-bibtex-style', 'biblatex-gb7714-2025', 'citeproc-lua']
    | par-each { {
        processor: $in,
        versions: (nu $"($in).nu" collect-versions | from json),
    } }
    | transpose --header-row --as-record
    | to yaml
}
